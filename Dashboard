    <div class="kpi-card"><div class="value" id="kpi-progress">—</div><div class="label">In Progress</div><div class="change down">↓ 3%</div></div>
    <div class="kpi-card"><div class="value" id="kpi-closed">—</div><div class="label">Closed</div><div class="change down">↓ 5% avg resolution</div></div>
    <div class="kpi-card"><div class="value" id="kpi-avgres">—</div><div class="label">Avg Resolution (days)</div><div class="change down">↓ 0.8 days</div></div>
  </div>
  <div class="grid-2">
    <div class="card"><h3>Complaints by Type</h3><div class="chart-container"><canvas id="chartType"></canvas></div></div>
    <div class="card"><h3>Complaints by Priority</h3><div class="chart-container"><canvas id="chartPriority"></canvas></div></div>
  </div>
