const keywordMap = {
  "Lamp Out": ["out","dark","dead","not working","no light","pitch black","stopped","gone out","darkness","completely out"],
  "Flickering": ["flicker","blink","strobe","intermittent","on and off","blinking","strobing","flashing","flickering"],
  "Damaged Pole": ["leaning","bent","cracked","damaged","tilted","hit","knocked","rust","broken pole","fallen","pole"],
  "Partial Outage": ["multiple","several","block","consecutive","half","circuit","stretch","block-wide","many lights","outage"],
  "Buzzing Noise": ["buzz","hum","noise","crackling","humming","buzzing","loud","sound","vibrating"],
  "Daytime On": ["daytime","day","24/7","never turns off","always on","sensor","photocell","stays on","during the day"],
  "Dim Lamp": ["dim","faint","weak","barely","low light","progressively","useless","can't see","very dim"],
  "Exposed Wiring": ["exposed","wires","wiring","hanging","electrocution","shock","panel","open","dangerous wires","sticking out"]
};

function extractKeywords(text) {
  const lower = text.toLowerCase();
  const found = [];
  for (const [type, keywords] of Object.entries(keywordMap)) {
    for (const kw of keywords) {
      if (lower.includes(kw)) found.push({ keyword: kw, type });
    }
  }
  return found;
}

function classifyText(text) {
  const lower = text.toLowerCase();
  const scores = {};
  for (const [type, keywords] of Object.entries(keywordMap)) {
    scores[type] = 0;
    for (const kw of keywords) {
      if (lower.includes(kw)) scores[type] += 1;
    }
  }
  if (lower.includes("exposed") || lower.includes("shock") || lower.includes("electrocution")) scores["Exposed Wiring"] += 3;
  if (lower.includes("leaning") || lower.includes("bent") || lower.includes("cracked")) scores["Damaged Pole"] += 3;
  if (lower.includes("flicker") || lower.includes("blink")) scores["Flickering"] += 2;
  if (lower.includes("multiple") || lower.includes("several") || lower.includes("block")) scores["Partial Outage"] += 2;
  if (lower.includes("buzz") || lower.includes("hum") || lower.includes("noise")) scores["Buzzing Noise"] += 2;
  if (lower.includes("dim") || lower.includes("faint")) scores["Dim Lamp"] += 2;
  if (lower.includes("daytime") || lower.includes("stays on") || lower.includes("never off")) scores["Daytime On"] += 2;
  if (lower.includes("out") || lower.includes("dead") || lower.includes("not working") || lower.includes("dark")) scores["Lamp Out"] += 1;

  const sorted = Object.entries(scores).sort((a, b) => b[1] - a[1]);
  const maxScore = sorted[0][1];
  if (maxScore === 0) return { type: "Lamp Out", confidence: 0.3, allScores: sorted };
  const total = sorted.reduce((s, e) => s + e[1], 0);
  return { type: sorted[0][0], confidence: Math.min(0.98, sorted[0][1] / Math.max(1, total) + 0.2), allScores: sorted };
}

function determinePriority(type, text) {
  const lower = text.toLowerCase();
  const urgentWords = ["dangerous","unsafe","hazard","emergency","urgent","kids","children","elderly","accident","electrocution","shock","fall","dark","pitch black"];
  let urgencyBoost = 0;
  for (const w of urgentWords) { if (lower.includes(w)) urgencyBoost += 0.12; }
  const basePriority = { "Exposed Wiring": 0.9, "Damaged Pole": 0.75, "Partial Outage": 0.7, "Lamp Out": 0.5, "Flickering": 0.35, "Dim Lamp": 0.3, "Buzzing Noise": 0.25, "Daytime On": 0.2 };
  const score = Math.min(1, (basePriority[type] || 0.4) + urgencyBoost);
  const priority = score >= 0.7 ? "High" : score >= 0.4 ? "Medium" : "Low";
  return { priority, urgencyScore: score };
}

// ================================================================
// SIMILARITY ENGINE
// ================================================================
function complaintFeatureVector(c) {
  const typeIdx = complaintTypes.indexOf(c.type);
  const typeVec = complaintTypes.map((_, i) => i === typeIdx ? 1 : 0);
  const zipIdx = siZips.indexOf(c.zip);
  const zipVec = siZips.map((_, i) => i === zipIdx ? 1 : 0);
  const priVec = priorities.map(p => p === c.priority ? 1 : 0);
  const statusVec = statuses.map(s => s === c.status ? 1 : 0);
  const monthNorm = c.month / 11;
  const resNorm = c.resolution ? c.resolution / 14 : 0.5;
  return [...typeVec, ...zipVec, ...priVec, ...statusVec, monthNorm, resNorm];
}

function cosineSim(a, b, weights) {
  let dot = 0, magA = 0, magB = 0;
  for (let i = 0; i < a.length; i++) {
    const w = weights ? (weights[i] || 1) : 1;
    dot += a[i] * b[i] * w; magA += a[i] * a[i] * w; magB += b[i] * b[i] * w;
  }
  return magA && magB ? dot / (Math.sqrt(magA) * Math.sqrt(magB)) : 0;
}

function getWeights(mode) {
  const w = new Array(28).fill(1);
  if (mode === "type") { for (let i = 0; i < 8; i++) w[i] = 4; }
  if (mode === "location") { for (let i = 8; i < 20; i++) w[i] = 4; }
  if (mode === "time") { w[26] = 5; }
  return w;
}

function findSimilar(sourceId, mode, count) {
  const source = calls.find(c => c.id === sourceId);
  if (!source) return [];
  const sourceVec = complaintFeatureVector(source);
  const weights = getWeights(mode);
  const sourceKw = new Set(extractKeywords(source.description).map(k => k.keyword));
  const results = calls.filter(c => c.id !== sourceId).map(c => {
    const vec = complaintFeatureVector(c);
    let sim = cosineSim(sourceVec, vec, weights);
    const cKw = new Set(extractKeywords(c.description).map(k => k.keyword));
    const overlap = [...sourceKw].filter(k => cKw.has(k)).length;
    const kwBonus = overlap / Math.max(1, Math.max(sourceKw.size, cKw.size)) * 0.15;
    sim = Math.min(1, sim + kwBonus);
    return { ...c, similarity: sim };
  }).sort((a, b) => b.similarity - a.similarity).slice(0, count);
  return results;
}

