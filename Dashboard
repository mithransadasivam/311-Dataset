      <button class="btn btn-secondary" onclick="loadExample()">💡 Load Example</button>
    </div>
    <div id="classifier-result"></div>
  </div>
  <div class="grid-2" style="margin-top:24px;">
    <div class="card">
      <h3>Classification Distribution</h3>
      <div class="chart-container"><canvas id="chartClassDist"></canvas></div>
    </div>
    <div class="card">
      <h3>Priority by Complaint Type</h3>
      <div class="chart-container"><canvas id="chartPriorityType"></canvas></div>
    </div>
  </div>
</div>

<!-- ==================== SIMILARITY SEARCH TAB ==================== -->
<div class="dashboard" id="tab-similarity">
  <div class="card">
    <h3>🔍 Complaint Similarity Search</h3>
    <p style="color:#8899aa;font-size:0.85rem;margin-bottom:16px;">Select a complaint from the table or search by ID, then find the most similar complaints based on type, location, priority, time, and description keywords.</p>
    <div class="search-box">
      <input class="search-input" id="simSearchInput" placeholder="Search by Complaint ID (e.g. SI-100042) or type keywords..." />
      <button class="btn" onclick="searchComplaint()">Search</button>
    </div>
    <div class="clf-row" style="margin-top:0;margin-bottom:16px;">
      <div class="form-group">
        <label>Or pick a random complaint</label>
        <button class="btn btn-secondary" onclick="pickRandom()">🎲 Random Complaint</button>
      </div>
      <div class="form-group">
        <label>Similarity Weights</label>
        <select id="simWeightMode" onchange="rerunSimilarity()">
          <option value="balanced">Balanced</option>
          <option value="location">Location-Heavy</option>
          <option value="type">Type-Heavy</option>
          <option value="time">Time-Heavy</option>
        </select>
      </div>
      <div class="form-group">
        <label>Results</label>
        <select id="simCount" onchange="rerunSimilarity()">
          <option value="10">Top 10</option>
          <option value="20">Top 20</option>
          <option value="50">Top 50</option>
        </select>
      </div>
    </div>
    <div id="simSourceCard"></div>
    <div id="simResults"></div>
  </div>
  <div class="grid-2" style="margin-top:24px;">
    <div class="card">
      <h3>Similarity Score Distribution</h3>
      <div class="chart-container"><canvas id="chartSimDist"></canvas></div>
    </div>
    <div class="card">
      <h3>Similar Complaints by Zip Code</h3>
      <div class="chart-container"><canvas id="chartSimZip"></canvas></div>
    </div>
  </div>
</div>

<!-- ==================== VENDORS TAB ==================== -->
<div class="dashboard" id="tab-vendors">
