  .status-progress { background: rgba(255,183,3,0.2); color: #ffb703; }
  .status-closed { background: rgba(46,196,182,0.2); color: #2ec4b6; }
  .priority-high { color: #e63946; font-weight: 700; }
  .priority-medium { color: #ffb703; font-weight: 600; }
  .priority-low { color: #2ec4b6; }

  /* Classifier */
  .clf-textarea { width: 100%; background: #0d1b2a; border: 1px solid #334455; color: #e0e0e0; padding: 14px 16px; border-radius: 10px; font-size: 0.95rem; font-family: inherit; resize: vertical; min-height: 80px; }
