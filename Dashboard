      <div class="result-row"><span class="result-label">Priority</span><span class="result-value ${sPri}">${source.priority}</span></div>
      <div class="result-row"><span class="result-label">Status</span><span class="result-value"><span class="status-badge ${sClass}">${source.status}</span></span></div>
      <div class="result-row"><span class="result-label">Location</span><span class="result-value">${source.address}, SI ${source.zip}</span></div>
      <div class="result-row"><span class="result-label">Vendor</span><span class="result-value">${source.vendor}</span></div>
      <div class="result-row"><span class="result-label">Description</span><span class="result-value" style="max-width:60%;text-align:right">${source.description}</span></div>
    </div>`;

  let html = `<h4 style="color:#00b4d8;margin-bottom:16px;">🔗 Top ${similar.length} Similar Complaints</h4>`;
  similar.forEach((c, i) => {
    const cClass = c.status === "Open" ? "status-open" : c.status === "In Progress" ? "status-progress" : "status-closed";
    const cPri = c.priority === "High" ? "priority-high" : c.priority === "Medium" ? "priority-medium" : "priority-low";
    const simPct = (c.similarity * 100).toFixed(1);
    const fillClass = c.similarity > 0.8 ? "fill-blue" : c.similarity > 0.5 ? "fill-med" : "fill-low";
    html += `<div class="sim-complaint-card" onclick="document.getElementById('simSearchInput').value='${c.id}';searchComplaint();">
      <div style="display:flex;justify-content:space-between;align-items:center">
        <div><strong>${c.id}</strong> <span class="tag tag-type">${c.type}</span> <span class="${cPri}" style="font-size:0.78rem">${c.priority}</span></div>
        <div><span class="sim-score">${simPct}%</span> <span class="confidence-bar"><span class="confidence-fill ${fillClass}" style="width:${simPct}%"></span></span></div>
      </div>
      <div class="sim-desc">${c.description.substring(0, 150)}...</div>
      <div class="sim-meta">${c.dateStr} • ${c.address}, ${c.zip} • <span class="status-badge ${cClass}">${c.status}</span> • ${c.vendor} ${c.resolution ? '• Resolved in ' + c.resolution + 'd' : ''}</div>
    </div>`;
  });
  document.getElementById('simResults').innerHTML = html;

  // Similarity distribution chart
  const simBuckets = [0,0,0,0,0];
  similar.forEach(c => { const idx = Math.min(4, Math.floor(c.similarity * 5)); simBuckets[idx]++; });
  if (simDistChart) simDistChart.destroy();
  simDistChart = new Chart(document.getElementById('chartSimDist'), {
    type: 'bar',
    data: { labels: ['0-20%','20-40%','40-60%','60-80%','80-100%'], datasets: [{ label: 'Count', data: simBuckets, backgroundColor: ['#e63946','#ffb703','#0077b6','#0096c7','#00b4d8'], borderRadius: 6 }] },
    options: { responsive: true, maintainAspectRatio: false, scales: { x: { ticks: { color: '#8899aa' }, grid: { display: false } }, y: { ticks: { color: '#8899aa' }, grid: { color: '#1a2a3a' } } }, plugins: { legend: { display: false } } }
  });

  // Similar by zip chart
  const simZipCounts = siZips.map(z => similar.filter(c => c.zip === z).length);
  if (simZipChart) simZipChart.destroy();
  simZipChart = new Chart(document.getElementById('chartSimZip'), {
    type: 'bar',
    data: { labels: siZips, datasets: [{ label: 'Similar Complaints', data: simZipCounts, backgroundColor: '#00b4d8', borderRadius: 6 }] },
    options: { responsive: true, maintainAspectRatio: false, scales: { x: { ticks: { color: '#8899aa' }, grid: { display: false } }, y: { ticks: { color: '#8899aa' }, grid: { color: '#1a2a3a' } } }, plugins: { legend: { labels: { color: '#8899aa' } } } }
  });
}

// ================================================================
// VENDOR TABLE
// ================================================================
const vendorBody = document.getElementById('vendorTableBody');
vendors.forEach(v => {
  const vCalls = calls.filter(c => c.vendor === v.business);
  const closed = vCalls.filter(c => c.resolution);
  const avg = closed.length > 0 ? (closed.reduce((s, c) => s + c.resolution, 0) / closed.length).toFixed(1) + "d" : "—";
  const topType = complaintTypes.reduce((best, t) => {
    const cnt = vCalls.filter(c => c.type === t).length;
    return cnt > best.count ? { type: t, count: cnt } : best;
  }, { type: "—", count: 0 });
  vendorBody.innerHTML += `<tr><td>${v.license}</td><td>${v.name}</td><td>${v.business}</td><td>${v.address}</td><td>${v.zip}</td><td>${v.phone}</td><td>${vCalls.length}</td><td>${avg}</td><td><span class="tag tag-type">${topType.type}</span></td></tr>`;
});

// ================================================================
// ALL CALLS TABLE
// ================================================================
const filterTypeSelect = document.getElementById('filterType');
complaintTypes.forEach(t => { const opt = document.createElement('option'); opt.value = t; opt.textContent = t; filterTypeSelect.appendChild(opt); });
const filterVendorSelect = document.getElementById('filterVendor');
vendors.forEach(v => { const opt = document.createElement('option'); opt.value = v.business; opt.textContent = v.business; filterVendorSelect.appendChild(opt); });

function renderCalls(data) {
  const tbody = document.getElementById('callsTableBody');
  tbody.innerHTML = '';
  document.getElementById('callCount').textContent = data.length;
  data.forEach(c => {
    const statusClass = c.status === "Open" ? "status-open" : c.status === "In Progress" ? "status-progress" : "status-closed";
    const priClass = c.priority === "High" ? "priority-high" : c.priority === "Medium" ? "priority-medium" : "priority-low";
    tbody.innerHTML += `<tr>
      <td>${c.id}</td><td>${c.dateStr}</td><td><span class="tag tag-type">${c.type}</span></td>
      <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="${c.description}">${c.description.substring(0, 60)}...</td>
      <td>${c.address}</td><td>${c.zip}</td>
      <td class="${priClass}">${c.priority}</td><td><span class="status-badge ${statusClass}">${c.status}</span></td>
      <td style="font-size:0.78rem">${c.vendor}</td><td>${c.resolution || '—'}</td>
      <td><button class="btn btn-secondary" style="padding:4px 10px;font-size:0.72rem" onclick="goToSimilarity('${c.id}')">Find Similar</button></td></tr>`;
  });
}

function filterCalls() {
  let filtered = [...calls];
  const s = document.getElementById('filterStatus').value;
  const p = document.getElementById('filterPriority').value;
  const t = document.getElementById('filterType').value;
  const v = document.getElementById('filterVendor').value;
  if (s !== 'all') filtered = filtered.filter(c => c.status === s);
  if (p !== 'all') filtered = filtered.filter(c => c.priority === p);
  if (t !== 'all') filtered = filtered.filter(c => c.type === t);
  if (v !== 'all') filtered = filtered.filter(c => c.vendor === v);
  renderCalls(filtered);
}

function resetFilters() {
  document.getElementById('filterStatus').value = 'all';
  document.getElementById('filterPriority').value = 'all';
  document.getElementById('filterType').value = 'all';
  document.getElementById('filterVendor').value = 'all';
  renderCalls(calls);
}

renderCalls(calls);

// ================================================================
// TAB SWITCHING
// ================================================================
function switchTab(tab, el) {
  document.querySelectorAll('.dashboard').forEach(d => d.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.getElementById('tab-' + tab).classList.add('active');
  if (el) el.classList.add('active');
}
</script>
</body>
</html>
