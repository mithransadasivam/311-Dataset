const dayNames = ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"];

function weightedRandom(items, weights) {
  let r = Math.random(), cum = 0;
  for (let i = 0; i < items.length; i++) { cum += weights[i]; if (r <= cum) return items[i]; }
  return items[items.length - 1];
}

function randomDate(start, end) {
  return new Date(start.getTime() + Math.random() * (end.getTime() - start.getTime()));
}

function generateDescription(type, street, addr) {
  const templates = descTemplates[type];
  let desc = templates[Math.floor(Math.random() * templates.length)];
  desc = desc.replace(/{street}/g, street);
  desc = desc.replace(/{addr}/g, addr);
  desc = desc.replace(/{days}/g, Math.floor(Math.random() * 14) + 2);
  desc = desc.replace(/{day}/g, dayNames[Math.floor(Math.random() * dayNames.length)]);
  desc = desc.replace(/{cross1}/g, crossStreets[Math.floor(Math.random() * crossStreets.length)]);
  desc = desc.replace(/{cross2}/g, crossStreets[Math.floor(Math.random() * crossStreets.length)]);
  return desc;
}

function generateCalls(n) {
  const calls = [];
  for (let i = 0; i < n; i++) {
    const type = weightedRandom(complaintTypes, typeWeights);
    const priority = type === "Exposed Wiring" || type === "Damaged Pole" ? (Math.random() < 0.7 ? "High" : "Medium") :
                     type === "Lamp Out" || type === "Partial Outage" ? (Math.random() < 0.4 ? "High" : (Math.random() < 0.6 ? "Medium" : "Low")) :
                     (Math.random() < 0.15 ? "High" : (Math.random() < 0.5 ? "Medium" : "Low"));
    const status = Math.random() < 0.22 ? "Open" : (Math.random() < 0.35 ? "In Progress" : "Closed");
    const vendor = vendors[Math.floor(Math.random() * vendors.length)];
    const date = randomDate(new Date(2025, 3, 1), new Date(2026, 3, 14));
    const resolution = status === "Closed" ? Math.floor(Math.random() * 14) + 1 : null;
    const streetNum = Math.floor(Math.random() * 900) + 100;
    const street = siStreets[Math.floor(Math.random() * siStreets.length)];
    const addr = `${streetNum} ${street}`;
    const zip = siZips[Math.floor(Math.random() * siZips.length)];
    const description = generateDescription(type, street, addr);
    calls.push({
      id: `SI-${String(100001 + i)}`,
      date, dateStr: date.toLocaleDateString('en-US'),
      month: date.getMonth(), year: date.getFullYear(),
      type, priority, status, description,
      address: addr, street, zip,
      vendor: vendor.business, vendorName: vendor.name, vendorZip: vendor.zip,
      resolution
    });
  }
  return calls.sort((a, b) => b.date - a.date);
}

